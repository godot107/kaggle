# Data — never commit raw datasets (but keep the folders via .gitkeep)
**/data/raw/*
**/data/interim/*
**/data/processed/*
*.csv
*.parquet
*.zip
!**/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/
.python-version

# Notebooks scratch outputs
*-checkpoint.ipynb

# Env / secrets
.env
kaggle.json

# OS / editor
.DS_Store
.vscode/
.idea/
